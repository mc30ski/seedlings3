enum JobKind {
  ENTIRE_SITE
  SINGLE_ADDRESS
}

enum JobStatus {
  PROPOSED
  ACCEPTED
  PAUSED
  ARCHIVED
}

enum Cadence {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum JobOccurrenceStatus {
  SCHEDULED
  IN_PROGRESS
  PAUSED
  COMPLETED
  PENDING_PAYMENT
  CLOSED
  CANCELED
  ARCHIVED
  PROPOSAL_SUBMITTED
  ACCEPTED
  REJECTED
}

enum OccurrenceWorkflow {
  STANDARD
  ONE_OFF
  ESTIMATE
  TASK
  REMINDER
  EVENT
  FOLLOWUP
  ANNOUNCEMENT
}

enum JobOccurrenceSource {
  GENERATED
  MANUAL
}

model Job {
  id String @id @default(cuid())

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  kind   JobKind   @default(SINGLE_ADDRESS) // REQUIRED
  status JobStatus @default(PROPOSED)

  frequencyDays    Int?
  description      String?
  notes            String?
  defaultPrice     Float?
  estimatedMinutes Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Default crew. EITHER set `defaultGroupId` (and the JobAssigneeDefault
  // list stays empty) OR populate JobAssigneeDefault rows — not both. The
  // mode is enforced in app code (services/jobs.ts). When defaultGroupId
  // is set, new occurrences materialize the group's full roster.
  defaultGroupId   String?
  defaultGroup     Group?  @relation("JobDefaultGroup", fields: [defaultGroupId], references: [id], onDelete: SetNull)

  contacts JobContact[]
  clients  JobClient[]

  schedule               JobSchedule?
  occurrences            JobOccurrence[]
  defaultAssignees       JobAssigneeDefault[]
  defaultPropertyPhotos  JobPropertyPhoto[]
  followups              FollowupJob[]
  recommendedCollections JobRecommendedCollection[]

  @@index([defaultGroupId])
}

model JobContact {
  id String @id @default(cuid())

  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  clientContactId String
  clientContact   ClientContact @relation(fields: [clientContactId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  role   String // "decision_maker" | "on_site" | "notify_only"
  notify Boolean @default(true)

  @@index([jobId])
  @@index([clientContactId])
}

model JobClient {
  id String @id @default(cuid())

  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  role  String // "owner" | "payer" | "point_of_contact"
  share Float? // optional split %

  @@index([jobId])
  @@index([clientId])
}

model JobSchedule {
  id String @id @default(cuid())

  jobId String @unique
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  autoRenew Boolean @default(false)

  cadence  Cadence?
  interval Int? // every N weeks/months (simple)

  dayOfWeek  Int? // 0-6 for weekly-ish schedules
  dayOfMonth Int? // 1-31 for monthly-ish schedules

  preferredStartHour Int?
  preferredEndHour   Int?

  horizonDays    Int       @default(21)
  nextGenerateAt DateTime?
  active         Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JobOccurrence {
  id String @id @default(cuid())

  jobId String?
  job   Job?    @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  kind JobKind? // Copied from Job.kind on creation; null for tasks

  title String? // Short title for tasks; optional for job occurrences

  startAt DateTime?
  endAt   DateTime?

  status   JobOccurrenceStatus @default(SCHEDULED)
  source   JobOccurrenceSource @default(GENERATED)
  workflow OccurrenceWorkflow  @default(STANDARD)

  jobType                    String? // Legacy/custom free-text job type
  jobTags                    String? // JSON array of tags, e.g. ["MOW","TRIM","EDGE","BLOW"]
  notes                      String?
  price                      Float?
  estimatedMinutes           Int?
  frequencyDays              Int? // Overrides Job.frequencyDays when set
  proposalAmount             Float?
  proposalNotes              String?
  rejectionReason            String?
  generatedEstimate          String? // AI-generated estimate message for client
  generatedEstimateBreakdown String? // AI-generated internal cost breakdown for business
  // Light estimate fields (used when jobId is null and workflow is ESTIMATE)
  contactName                String?
  contactPhone               String?
  contactEmail               String?
  estimateAddress            String?

  isOneOff          Boolean @default(false) // @deprecated — use workflow
  isTentative       Boolean @default(false)
  isEstimate        Boolean @default(false) // @deprecated — use workflow
  isAdminOnly       Boolean @default(false)
  isClientConfirmed Boolean @default(false)
  isHighPriority    Boolean @default(false)
  pinnedNote        String?
  pinnedNoteRepeats Boolean @default(true)

  startedAt     DateTime?
  completedAt   DateTime?
  pausedAt      DateTime?
  totalPausedMs Int       @default(0)

  startLat    Float?
  startLng    Float?
  completeLat Float?
  completeLng Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  linkedOccurrenceId String?
  linkedOccurrence   JobOccurrence?  @relation("TaskLink", fields: [linkedOccurrenceId], references: [id], onDelete: SetNull)
  linkedFromTasks    JobOccurrence[] @relation("TaskLink")

  linkGroupId String?

  // Set when admin attached a Group (crew) or the claimer claimed for a group.
  // Members are materialized into `assignees` at attach/claim time — this
  // column is the back-link so we can render "Group: Alpha (5)" and enforce
  // the group-vs-individual exclusivity rule.
  assignedGroupId String?
  assignedGroup   Group?  @relation("OccurrenceGroup", fields: [assignedGroupId], references: [id], onDelete: SetNull)

  assignees        JobOccurrenceAssignee[]
  payment          Payment?
  expenses         Expense[]
  businessExpenses BusinessExpense[]
  supplyHolds      SupplyHold[]
  addons           OccurrenceAddon[]
  instructions     OccurrenceInstruction[]
  photos           JobOccurrencePhoto[]
  propertyPhotos   OccurrencePropertyPhoto[]
  pins             PinnedOccurrence[]
  likes            LikedOccurrence[]
  reminders        Reminder[]
  comments         OccurrenceComment[]
  followupClients  FollowupClient[]
  followupJobs     FollowupJob[]
  changeRequests   OccurrenceChangeRequest[]

  @@index([linkGroupId])
  @@index([assignedGroupId])
  @@index([jobId, status])
  @@index([startAt])
  @@index([kind])
}

model JobOccurrencePhoto {
  id String @id @default(cuid())

  occurrenceId String
  occurrence   JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  r2Key       String // object key in R2 bucket
  fileName    String? // original file name
  contentType String? // e.g. image/jpeg

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id], onDelete: Restrict, onUpdate: Cascade)

  createdAt DateTime @default(now())

  @@index([occurrenceId])
}

model JobAssigneeDefault {
  id String @id @default(cuid())

  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  role      String? // "observer" for observer role, null for worker
  active    Boolean @default(true)
  // Lower sortOrder = appears first. The first non-observer (sorted asc) is
  // treated as the default claimer when generating occurrences.
  sortOrder Int     @default(100)

  createdAt DateTime @default(now())

  @@unique([jobId, userId])
  @@index([jobId, active])
  @@index([userId])
}

model JobOccurrenceAssignee {
  id String @id @default(cuid())

  occurrenceId String
  occurrence   JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  role       String?
  assignedAt DateTime @default(now())

  assignedById String?
  assignedBy   User?   @relation("JobAssignActor", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([occurrenceId, userId])
  @@index([occurrenceId])
  @@index([userId])
  @@index([assignedById])
}

enum PaymentMethod {
  CASH
  CHECK
  VENMO
  ZELLE
  APPLE_PAY
  CASH_APP
  OTHER
}

model Payment {
  id String @id @default(cuid())

  occurrenceId String        @unique
  occurrence   JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  amountPaid Float
  method     PaymentMethod
  note       String?

  platformFeePercent    Float? // % charged to contractor/unclassified
  platformFeeAmount     Float? // calculated on contractor splits: (splitAmount - expenses) * percent / 100
  businessMarginPercent Float? // % retained from employee/trainee splits
  businessMarginAmount  Float? // calculated on employee/trainee splits: (splitAmount - expenses) * percent / 100

  collectedById String
  collectedBy   User   @relation(fields: [collectedById], references: [id], onDelete: Restrict, onUpdate: Cascade)

  nextOccurrenceSkipReason String? // null = created successfully, "one_off" = expected, others = warning

  splits PaymentSplit[]

  createdAt DateTime @default(now())

  @@index([collectedById, createdAt])
  @@index([method, createdAt])
}

model PaymentSplit {
  id String @id @default(cuid())

  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  amount Float

  createdAt DateTime @default(now())

  @@unique([paymentId, userId])
  @@index([userId, createdAt])
}

model Expense {
  id String @id @default(cuid())

  occurrenceId String
  occurrence   JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Restrict, onUpdate: Cascade)

  cost        Float
  description String

  // 1:1 link to the BusinessExpense (tax ledger) row. Every Expense added on
  // a job in MVP-step-2 onward gets a paired BusinessExpense — workers buy on
  // the company card, so per-job spend IS a business expense.
  businessExpenseId String?          @unique
  businessExpense   BusinessExpense? @relation(fields: [businessExpenseId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // Back-relation: when this Expense was created by consuming inventory
  // (MVP-step-3), the SupplyHold owns the link via SupplyHold.expenseId.
  // No BusinessExpense is paired in this case — the BE was already recorded
  // at purchase time, and double-recording would inflate tax-ledger totals.
  supplyHold SupplyHold?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([occurrenceId])
  @@index([createdById])
}

// Business expenses NOT tied to a specific job/occurrence — used for general bookkeeping (insurance, fuel, equipment purchases, etc.)
model BusinessExpense {
  id String @id @default(cuid())

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Restrict, onUpdate: Cascade)

  date          DateTime
  cost          Float
  description   String
  category      String?
  vendor        String?
  invoiceNumber String?
  notes         String?

  // Optional link to a piece of equipment — useful for capital purchases
  // (e.g. "$8K rider mower" categorized as Depreciation gets linked to its
  // Equipment row so we can track per-equipment lifetime cost later).
  equipmentId String?
  equipment   Equipment? @relation(fields: [equipmentId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // Optional link to a job occurrence — set when the expense was incurred for
  // a specific job (worker buys gas on the company card). The corresponding
  // per-Job Expense row drives payout reduction; this row is the tax ledger
  // entry. Linked 1:1 via Expense.businessExpenseId.
  occurrenceId String?
  occurrence   JobOccurrence? @relation(fields: [occurrenceId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  expense      Expense?

  // Back-relation: when this BE was created by an inventory purchase
  // (MVP-step-3), the SupplyPurchase owns the link via
  // SupplyPurchase.businessExpenseId. Allows the tax-ledger UI to surface a
  // "Supply: Mulch ×10" badge and link back to the Supplies tab.
  supplyPurchase SupplyPurchase?

  // Optional receipt photo. Stored in the seedlings-receipts R2 bucket; the
  // R2 key is the canonical reference. Same anchor for all 3 expense
  // sources (freestanding BE, job-Expense pair, supply-purchase pair).
  receiptR2Key       String?
  receiptFileName    String?
  receiptContentType String?
  receiptUploadedAt  DateTime?

  // Optional cadence flag for recurring expenses (e.g. monthly software
  // subscriptions). Null = one-off. The most recent row in a group keyed
  // by (description, vendor) drives "due to record" suggestions.
  recurrence ExpenseRecurrence?

  // When set, the next-expected date for the series is computed from this
  // date instead of `date + cadence`. Used by the "Skip" button on the Due
  // to record panel: skipping the May invoice sets this to the May expected
  // date, so the next suggestion is one cadence later.
  recurrenceSkippedUntil DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([category])
  @@index([createdById])
  @@index([equipmentId])
  @@index([occurrenceId])
}

