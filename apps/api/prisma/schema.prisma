model FollowupJob {
  id           String        @id @default(cuid())
  occurrenceId String
  occurrence   JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  jobId        String
  job          Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())

  @@unique([occurrenceId, jobId])
}

// ── Property Photos & Instructions ──────────────────────────────────────────

model PropertyPhoto {
  id           String   @id @default(cuid())
  propertyId   String
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  r2Key        String
  fileName     String?
  contentType  String?
  description  String?
  sortOrder    Int      @default(0)
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  createdAt    DateTime @default(now())

  jobDefaults    JobPropertyPhoto[]
  occurrenceRefs OccurrencePropertyPhoto[]

  @@index([propertyId])
}

model JobPropertyPhoto {
  id              String        @id @default(cuid())
  jobId           String
  job             Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  propertyPhotoId String
  propertyPhoto   PropertyPhoto @relation(fields: [propertyPhotoId], references: [id], onDelete: Cascade)

  @@unique([jobId, propertyPhotoId])
}

model OccurrencePropertyPhoto {
  id              String        @id @default(cuid())
  occurrenceId    String
  occurrence      JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  propertyPhotoId String
  propertyPhoto   PropertyPhoto @relation(fields: [propertyPhotoId], references: [id], onDelete: Cascade)

  @@unique([occurrenceId, propertyPhotoId])
}

// ── Add-on Services ─────────────────────────────────────────────────────────

model OccurrenceAddon {
  id           String        @id @default(cuid())
  occurrenceId String
  occurrence   JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  tag          String?
  customLabel  String?
  price        Float
  createdById  String
  createdBy    User          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime      @default(now())

  @@index([occurrenceId])
}

// ── Occurrence Instructions ─────────────────────────────────────────────────

model OccurrenceInstruction {
  id           String        @id @default(cuid())
  occurrenceId String
  occurrence   JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  text         String
  isPreset     Boolean       @default(false)
  repeats      Boolean       @default(true)
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())

  @@index([occurrenceId])
}

// ── Client-initiated change requests on a scheduled occurrence ──────────────
// Clients can request a reschedule (with proposed date) or skip a single
// occurrence. Admins approve/deny — approval applies the change.
enum ChangeRequestKind {
  RESCHEDULE
  SKIP
}

enum ChangeRequestStatus {
  PENDING
  APPROVED
  DENIED
  CANCELED
}

model OccurrenceChangeRequest {
  id              String              @id @default(cuid())
  occurrenceId    String
  occurrence      JobOccurrence       @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  requestedById   String
  requestedBy     User                @relation("ChangeRequestRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  kind            ChangeRequestKind
  status          ChangeRequestStatus @default(PENDING)
  proposedStartAt DateTime?
  comment         String?
  resolvedById    String?
  resolvedBy      User?               @relation("ChangeRequestResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolvedAt      DateTime?
  resolutionNote  String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([occurrenceId])
  @@index([requestedById])
  @@index([status])
}

// ── Supplies (MVP-step-3) ─────────────────────────────────────────────────────
//
// Inventory-tracked consumables. Decoupled from job-Expense so we can record
// the tax deduction at PURCHASE time (cash-method accounting) but charge the
// payout deduction at CONSUMPTION time, with optional markup.
//
//   Supply           = catalog row (one per SKU), tracks onHand
//   SupplyPurchase   = a buy event, paired 1:1 with a BusinessExpense (tax)
//   SupplyHold       = a consumption against an occurrence; ACTIVE reserves
//                      units, CONSUMED draws them down on completion
//   SupplyAdjustment = manual count corrections (no tax effect)

model Supply {
  id String @id @default(cuid())

  name          String
  description   String?
  unit          String // "bag", "spool", "lb"
  // For future UPC-scan add-flow. Nullable; not unique because the same
  // SKU could legitimately be entered twice with different display names.
  upc           String?
  // Schedule C category for the BusinessExpense paired with each purchase.
  // Defaults to "Supplies"; can be overridden per supply (e.g. "Car and
  // truck expenses" if you ever want to track fuel as inventory).
  category      String  @default("Supplies")
  // Reference businessCost — typically updated to the most recent
  // SupplyPurchase.unitCost. Display-only / default for new purchases.
  businessCost  Float   @default(0)
  // Per-unit charge to the job's payout when consumed. May exceed
  // businessCost — the difference is implicit business margin (similar to
  // platform fee / employee margin). Snapshot at hold time so retroactive
  // edits don't reprice existing holds.
  jobPayoutCost Float   @default(0)
  // Physical units in stock. Available = onHand − Σ(active holds), computed
  // at query time.
  onHand        Int     @default(0)

  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Restrict)

  purchases   SupplyPurchase[]
  holds       SupplyHold[]
  adjustments SupplyAdjustment[]

  @@index([archivedAt])
  @@index([upc])
  @@index([name])
}

model SupplyPurchase {
  id String @id @default(cuid())

  supplyId String
  supply   Supply @relation(fields: [supplyId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  quantity      Int
  unitCost      Float // per-unit cost at this purchase (snapshot)
  totalCost     Float // quantity × unitCost (denormalized for export)
  date          DateTime @default(now())
  vendor        String?
  invoiceNumber String?
  notes         String?

  // 1:1 link to the tax-ledger row created at the same time. Same dual-write
  // pattern as job Expense ↔ BusinessExpense in step-2. Restrict (not
  // Cascade): deleting the BE while a SupplyPurchase is linked would orphan
  // inventory; the BE-delete handler must reverse inventory and remove the
  // SupplyPurchase first.
  businessExpenseId String          @unique
  businessExpense   BusinessExpense @relation(fields: [businessExpenseId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([supplyId, date])
  @@index([date])
}

model SupplyHold {
  id String @id @default(cuid())

  supplyId String
  supply   Supply @relation(fields: [supplyId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  occurrenceId String
  occurrence   JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  quantity      Int
  jobPayoutCost Float // per-unit charge snapshot at hold time
  status        SupplyHoldStatus @default(ACTIVE)

  // 1:1 link to the per-job Expense row that drives payout deduction.
  // No paired BusinessExpense — the BE was created at purchase time;
  // recording another at consumption would double-count for taxes.
  expenseId String?  @unique
  expense   Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())
  consumedAt  DateTime?
  releasedAt  DateTime?
  updatedAt   DateTime  @updatedAt

  @@index([supplyId, status])
  @@index([occurrenceId])
  @@index([status])
}

model SupplyAdjustment {
  id String @id @default(cuid())

  supplyId String
  supply   Supply @relation(fields: [supplyId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  delta  Int // +N or −N units
  reason String

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())

  @@index([supplyId, createdAt])
}

enum SupplyHoldStatus {
  ACTIVE
  CONSUMED
  RELEASED
}

enum ExpenseRecurrence {
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

// EntryType discriminates the BusinessExpense table into the three kinds of
// "money out / money in" the Accounting tab tracks. All three land in the
// same table so receipt upload, recurrence, filters, and editing UI work
// identically; surfaces that mean "expenses only" (Schedule C export,
// vs-revenue P&L, qb-expenses CSV, summary) filter explicitly on
// type = EXPENSE. CAPITAL_CONTRIBUTION and OWNER_DRAW flow to QuickBooks via
// the equity export under standard sole-prop equity account names.
enum EntryType {
  EXPENSE
  CAPITAL_CONTRIBUTION
  OWNER_DRAW
}

// ─────────────────────────────────────────────────────────────────────────────
// Groups (crews)
//
// A Group is a saved roster of workers + observers led by a single claimer.
// Admins manage groups via Admin → Directory → Groups. A user can be in
// multiple groups. At job-assignment time the group is *materialized* into
// individual JobOccurrenceAssignee rows — the group is a template, not a
// live join. Mid-flight group edits never propagate to in-flight occurrences;
// see the lock check in services/groups.ts.
// ─────────────────────────────────────────────────────────────────────────────
model Group {
  id          String  @id @default(cuid())
  name        String
  description String? @db.Text

  claimerUserId String
  claimer       User   @relation("GroupClaimer", fields: [claimerUserId], references: [id], onDelete: Restrict)

  members            GroupMember[]
  preferredEquipment GroupPreferredEquipment[]

  // Back-relations
  occurrences JobOccurrence[] @relation("OccurrenceGroup")
  checkouts   Checkout[]
  defaultForJobs Job[]        @relation("JobDefaultGroup")

  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([claimerUserId])
  @@index([archivedAt])
}

model GroupMember {
  id      String @id @default(cuid())
  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  // "worker" (null in JobOccurrenceAssignee terms) or "observer"
  role String @default("worker")

  // Per-member share of group equipment costs. Null = even-split among
  // workers (observers always excluded). When any are non-null, every worker
  // in the group must have a value and they must sum to exactly 100.
  equipmentCostPercent Float?

  createdAt DateTime @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

// Preferred equipment + collections for a group. Display-only — never
// auto-reserves. Surfaces as a "Group preferred" panel on occurrences
// claimed by the group. Exactly one of equipmentId / equipmentCollectionId
// must be set (enforced in app code; no Prisma CHECK constraint).
model GroupPreferredEquipment {
  id      String @id @default(cuid())
  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  equipmentId           String?
  equipment             Equipment?           @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  equipmentCollectionId String?
  equipmentCollection   EquipmentCollection? @relation(fields: [equipmentCollectionId], references: [id], onDelete: Cascade)

  sortOrder Int      @default(100)
  createdAt DateTime @default(now())

  @@index([groupId, sortOrder])
  @@index([equipmentId])
  @@index([equipmentCollectionId])
}

// Company-level documents (Articles of Organization, Insurance certs, etc.).
// `type` is a string key into the DOCUMENT_TYPES setting taxonomy. A type can
// be flagged singleton in the taxonomy — enforced at the API layer.
// `currentVersionId` points at one of this doc's CompanyDocumentVersion rows.
model CompanyDocument {
  id          String  @id @default(cuid())
  type        String
  title       String
  description String?
  expiresAt   DateTime?
  // When true, Admins cannot see this document; only Super.
  adminHidden Boolean @default(false)

  // Pointer to the currently-active version. Nullable while doc has no
  // uploaded version yet (e.g., metadata created but file not yet PUT).
  currentVersionId String?                  @unique
  currentVersion   CompanyDocumentVersion?  @relation("CompanyDocCurrent", fields: [currentVersionId], references: [id], onDelete: SetNull)

  versions CompanyDocumentVersion[] @relation("CompanyDocVersions")

  createdById String
  createdBy   User   @relation("CompanyDocCreator", fields: [createdById], references: [id], onDelete: Restrict)

  archivedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([type, archivedAt])
  @@index([expiresAt])
}

model CompanyDocumentVersion {
  id         String @id @default(cuid())
  documentId String
  document   CompanyDocument @relation("CompanyDocVersions", fields: [documentId], references: [id], onDelete: Cascade)

  r2Key            String  @unique
  contentType      String
  originalFilename String
  sizeBytes        Int

  uploadedById String
  uploadedBy   User   @relation("CompanyDocVersionUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  uploadedAt   DateTime @default(now())

  // Back-relation for the currentVersion pointer on CompanyDocument.
  currentForDocument CompanyDocument? @relation("CompanyDocCurrent")

  @@index([documentId, uploadedAt])
}

// Timeline events — important upcoming dates surfaced in the Timeline tab
// alongside CompanyDocument expirations. `rrule` is a RFC 5545 RRULE string
// (e.g., "FREQ=YEARLY;BYMONTH=4;BYMONTHDAY=15"); empty/null = one-time at
// `anchorDate`. Hidden events (adminHidden=true) are visible to Super only.
model TimelineEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  // String key into the TIMELINE_CATEGORIES setting taxonomy. Null = no
  // category (uncategorized in the UI).
  category    String?
  rrule       String?
  // First/canonical occurrence — used as RRULE DTSTART. Immutable reference.
  anchorDate  DateTime
  // The currently-active due date. Starts at anchorDate on create. The user
  // explicitly advances it via "mark complete," which sets it to the next
  // rrule occurrence after the current value. If it drifts into the past
  // without being marked complete, the event renders as OVERDUE — that's the
  // whole point of this field vs. live-computing next-future-date.
  nextDueDate     DateTime?
  // Timestamp of the most recent "mark complete" action — used for display
  // ("last completed Jan 2026") and audit trail.
  lastCompletedAt DateTime?
  adminHidden Boolean  @default(false)
  archivedAt  DateTime?

  createdById String
  createdBy   User     @relation("TimelineEventCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([anchorDate])
  @@index([nextDueDate])
  @@index([archivedAt])
}

// Home-tab banner notifications. An admin posts a message to one or more
// users (or everyone); each recipient sees it on Worker Home until they
// individually dismiss it. Dismissals are per-user — one person dismissing
// has no effect on anyone else's view.
model BannerNotification {
  id          String   @id @default(cuid())
  title       String?
  body        String   @db.Text
  createdById String
  createdBy   User     @relation("BannerCreator", fields: [createdById], references: [id], onDelete: Restrict)
  // Optional self-expire — past this date the banner stops being shown to
  // anyone regardless of dismissal state. Null = no expiry.
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  recipients  BannerRecipient[]
  dismissals  BannerDismissal[]

  @@index([createdAt])
  @@index([expiresAt])
}

model BannerRecipient {
  id       String @id @default(cuid())
  bannerId String
  userId   String
  banner   BannerNotification @relation(fields: [bannerId], references: [id], onDelete: Cascade)
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bannerId, userId])
  @@index([userId])
}

model BannerDismissal {
  id           String   @id @default(cuid())
  bannerId     String
  userId       String
  dismissedAt  DateTime @default(now())
  banner       BannerNotification @relation(fields: [bannerId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bannerId, userId])
  @@index([userId])
}



// ─────────────────────────────────────────────────────────────────────────────
// Worker workday tracking — per-worker daily clock-in/out for payroll.
//
// Tracks total time the worker spent "on the clock" each day, independent
// of per-job duration. A workday has a startedAt, optional endedAt, and a
// pause/resume cycle (same shape as JobOccurrence) that accumulates into
// totalPausedMs. Active duration = (endedAt or now) − startedAt −
// totalPausedMs − (now − pausedAt if currently paused).
//
// Workday time is INTENTIONALLY DECOUPLED from JobOccurrence time:
//   - Workday measures "was this worker on the clock?" (payroll basis).
//   - JobOccurrence measures "how long did this job take?" (planning basis).
// In a crew, one worker can pause their workday for lunch while a coworker
// keeps mowing the job — the job clock keeps running, the lunching worker
// stops accruing paid time. Coupling them would force one of those two
// readings to be wrong; see the planning thread for the full design.
//
// `workdayDate` is the ET calendar date of check-in. Stays the anchor even
// if work runs past midnight (worker checks in at 11 PM Tuesday, ends at 2
// AM Wednesday — row remains anchored to Tuesday). The unique constraint
// enforces "one row per worker per anchor day."
//
// `approvedAt` / `approvedById` are reserved for the admin-approval phase
// (built next). Empty for now; the loader + audit log already account for
// them so the approval phase is purely additive.
// ─────────────────────────────────────────────────────────────────────────────
model WorkerWorkday {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation("WorkdayWorker", fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  workdayDate   String    // YYYY-MM-DD in ET

  startedAt     DateTime
  endedAt       DateTime?
  pausedAt      DateTime?
  totalPausedMs Int       @default(0)

  approvedAt    DateTime?
  approvedById  String?
  approvedBy    User?     @relation("WorkdayApprover", fields: [approvedById], references: [id], onDelete: SetNull, onUpdate: Cascade)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, workdayDate])
  @@index([userId, startedAt])
  @@index([workdayDate])
}
