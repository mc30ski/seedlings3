enum JobKind {
  ENTIRE_SITE
  SINGLE_ADDRESS
}

enum JobStatus {
  PROPOSED
  ACCEPTED
  PAUSED
  ARCHIVED
}

enum Cadence {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum JobOccurrenceStatus {
  SCHEDULED
  IN_PROGRESS
  PAUSED
  COMPLETED
  PENDING_PAYMENT
  CLOSED
  CANCELED
  ARCHIVED
  PROPOSAL_SUBMITTED
  ACCEPTED
  REJECTED
}

enum OccurrenceWorkflow {
  STANDARD
  ONE_OFF
  ESTIMATE
  TASK
  REMINDER
  EVENT
  FOLLOWUP
  ANNOUNCEMENT
}

enum JobOccurrenceSource {
  GENERATED
  MANUAL
}

model Job {
  id          String    @id @default(cuid())

  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  kind        JobKind   @default(SINGLE_ADDRESS) // REQUIRED
  status      JobStatus @default(PROPOSED)

  frequencyDays    Int?
  description      String?
  notes            String?
  defaultPrice     Float?
  estimatedMinutes Int?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  contacts    JobContact[]
  clients     JobClient[]

  schedule              JobSchedule?
  occurrences           JobOccurrence[]
  defaultAssignees      JobAssigneeDefault[]
  defaultPropertyPhotos JobPropertyPhoto[]
  followups             FollowupJob[]
}

model JobContact {
  id              String         @id @default(cuid())

  jobId           String
  job             Job            @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  clientContactId String
  clientContact   ClientContact  @relation(fields: [clientContactId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  role            String         // "decision_maker" | "on_site" | "notify_only"
  notify          Boolean        @default(true)

  @@index([jobId])
  @@index([clientContactId])
}

model JobClient {
  id        String   @id @default(cuid())

  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  role      String   // "owner" | "payer" | "point_of_contact"
  share     Float?   // optional split %

  @@index([jobId])
  @@index([clientId])
}

model JobSchedule {
  id        String  @id @default(cuid())

  jobId     String  @unique
  job       Job     @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  autoRenew Boolean @default(false)

  cadence   Cadence?
  interval  Int?       // every N weeks/months (simple)

  dayOfWeek Int?       // 0-6 for weekly-ish schedules
  dayOfMonth Int?      // 1-31 for monthly-ish schedules

  preferredStartHour Int?
  preferredEndHour   Int?

  horizonDays    Int      @default(21)
  nextGenerateAt DateTime?
  active         Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JobOccurrence {
  id          String   @id @default(cuid())

  jobId       String?
  job         Job?     @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  kind        JobKind?  // Copied from Job.kind on creation; null for tasks

  title       String?   // Short title for tasks; optional for job occurrences

  startAt     DateTime?
  endAt       DateTime?

  status      JobOccurrenceStatus @default(SCHEDULED)
  source      JobOccurrenceSource @default(GENERATED)
  workflow    OccurrenceWorkflow  @default(STANDARD)

  jobType          String?        // Legacy/custom free-text job type
  jobTags          String?        // JSON array of tags, e.g. ["MOW","TRIM","EDGE","BLOW"]
  notes            String?
  price            Float?
  estimatedMinutes Int?
  frequencyDays    Int?       // Overrides Job.frequencyDays when set
  proposalAmount   Float?
  proposalNotes    String?
  rejectionReason  String?
  generatedEstimate String?        // AI-generated estimate message for client
  generatedEstimateBreakdown String? // AI-generated internal cost breakdown for business
  // Light estimate fields (used when jobId is null and workflow is ESTIMATE)
  contactName      String?
  contactPhone     String?
  contactEmail     String?
  estimateAddress  String?

  isOneOff         Boolean @default(false)   // @deprecated — use workflow
  isTentative      Boolean @default(false)
  isEstimate       Boolean @default(false)   // @deprecated — use workflow
  isAdminOnly      Boolean @default(false)
  isClientConfirmed Boolean @default(false)
  isHighPriority   Boolean @default(false)
  pinnedNote          String?
  pinnedNoteRepeats   Boolean @default(true)

  startedAt             DateTime?
  completedAt           DateTime?
  pausedAt              DateTime?
  totalPausedMs         Int          @default(0)
  manualDurationMinutes Int?

  startLat    Float?
  startLng    Float?
  completeLat Float?
  completeLng Float?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  linkedOccurrenceId  String?
  linkedOccurrence    JobOccurrence?  @relation("TaskLink", fields: [linkedOccurrenceId], references: [id], onDelete: SetNull)
  linkedFromTasks     JobOccurrence[] @relation("TaskLink")

  linkGroupId         String?

  @@index([linkGroupId])

  assignees   JobOccurrenceAssignee[]
  payment     Payment?
  expenses    Expense[]
  addons       OccurrenceAddon[]
  instructions OccurrenceInstruction[]
  photos           JobOccurrencePhoto[]
  propertyPhotos   OccurrencePropertyPhoto[]
  pins             PinnedOccurrence[]
  likes            LikedOccurrence[]
  reminders        Reminder[]
  comments         OccurrenceComment[]
  followupClients  FollowupClient[]
  followupJobs     FollowupJob[]

  @@index([jobId, status])
  @@index([startAt])
  @@index([kind])
}

model JobOccurrencePhoto {
  id            String        @id @default(cuid())

  occurrenceId  String
  occurrence    JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  r2Key         String        // object key in R2 bucket
  fileName      String?       // original file name
  contentType   String?       // e.g. image/jpeg

  uploadedById  String
  uploadedBy    User          @relation(fields: [uploadedById], references: [id], onDelete: Restrict, onUpdate: Cascade)

  createdAt     DateTime      @default(now())

  @@index([occurrenceId])
}

model JobAssigneeDefault {
  id        String   @id @default(cuid())

  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  role      String?  // "observer" for observer role, null for worker
  active    Boolean  @default(true)

  createdAt DateTime @default(now())

  @@unique([jobId, userId])
  @@index([jobId, active])
  @@index([userId])
}

model JobOccurrenceAssignee {
  id            String        @id @default(cuid())

  occurrenceId  String
  occurrence    JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  role          String?
  assignedAt    DateTime      @default(now())

  assignedById  String?
  assignedBy    User?         @relation("JobAssignActor", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([occurrenceId, userId])
  @@index([occurrenceId])
  @@index([userId])
  @@index([assignedById])
}

enum PaymentMethod {
  CASH
  CHECK
  VENMO
  ZELLE
  APPLE_PAY
  CASH_APP
  OTHER
}

model Payment {
  id             String        @id @default(cuid())

  occurrenceId   String        @unique
  occurrence     JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  amountPaid     Float
  method         PaymentMethod
  note           String?

  platformFeePercent  Float?    // % charged to contractor/unclassified
  platformFeeAmount   Float?    // calculated on contractor splits: (splitAmount - expenses) * percent / 100
  businessMarginPercent Float?  // % retained from employee/trainee splits
  businessMarginAmount  Float?  // calculated on employee/trainee splits: (splitAmount - expenses) * percent / 100

  collectedById  String
  collectedBy    User          @relation(fields: [collectedById], references: [id], onDelete: Restrict, onUpdate: Cascade)

  splits         PaymentSplit[]

  createdAt      DateTime      @default(now())

  @@index([collectedById, createdAt])
  @@index([method, createdAt])
}

model PaymentSplit {
  id         String   @id @default(cuid())

  paymentId  String
  payment    Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  amount     Float

  createdAt  DateTime @default(now())

  @@unique([paymentId, userId])
  @@index([userId, createdAt])
}

model Expense {
  id            String        @id @default(cuid())

  occurrenceId  String
  occurrence    JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdById   String
  createdBy     User          @relation(fields: [createdById], references: [id], onDelete: Restrict, onUpdate: Cascade)

  cost          Float
  description   String

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([occurrenceId])
  @@index([createdById])
}

model Setting {
  id            String    @id @default(cuid())
  key           String    @unique
  value         String
  description   String?
  updatedAt     DateTime  @updatedAt
  updatedById   String?
  updatedBy     User?     @relation(fields: [updatedById], references: [id], onDelete: SetNull)
}

model PinnedOccurrence {
  id            String        @id @default(cuid())

  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  occurrenceId  String
  occurrence    JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)

  pinnedAt      DateTime      @default(now())

  @@unique([userId, occurrenceId])
  @@index([userId])
}

model LikedOccurrence {
  id            String        @id @default(cuid())

  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  occurrenceId  String
  occurrence    JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)

  likedAt       DateTime      @default(now())

  @@unique([userId, occurrenceId])
  @@index([userId])
}

model OccurrenceComment {
  id            String        @id @default(cuid())

  occurrenceId  String
  occurrence    JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)

  authorId      String
  author        User          @relation(fields: [authorId], references: [id], onDelete: Cascade)

  body          String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([occurrenceId])
  @@index([authorId])
}

model CalendarFeedToken {
  id              String    @id @default(cuid())

  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  token           String    @unique
  label           String?
  filters         Json
  createdAt       DateTime  @default(now())
  lastAccessedAt  DateTime?

  @@index([userId])
  @@index([token])
}

model Reminder {
  id            String        @id @default(cuid())

  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  occurrenceId  String
  occurrence    JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)

  remindAt      DateTime
  note          String?
  dismissedAt   DateTime?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([userId, occurrenceId])
  @@index([userId, remindAt])
}

model FollowupClient {
  id            String        @id @default(cuid())
  occurrenceId  String
  occurrence    JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())

  @@unique([occurrenceId, clientId])
}

model FollowupJob {
  id            String        @id @default(cuid())
  occurrenceId  String
  occurrence    JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  jobId         String
  job           Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())

  @@unique([occurrenceId, jobId])
}

// ── Property Photos & Instructions ──────────────────────────────────────────

model PropertyPhoto {
  id           String   @id @default(cuid())
  propertyId   String
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  r2Key        String
  fileName     String?
  contentType  String?
  description  String?
  sortOrder    Int      @default(0)
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  createdAt    DateTime @default(now())

  jobDefaults    JobPropertyPhoto[]
  occurrenceRefs OccurrencePropertyPhoto[]

  @@index([propertyId])
}

model JobPropertyPhoto {
  id              String        @id @default(cuid())
  jobId           String
  job             Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  propertyPhotoId String
  propertyPhoto   PropertyPhoto @relation(fields: [propertyPhotoId], references: [id], onDelete: Cascade)

  @@unique([jobId, propertyPhotoId])
}

model OccurrencePropertyPhoto {
  id              String         @id @default(cuid())
  occurrenceId    String
  occurrence      JobOccurrence  @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  propertyPhotoId String
  propertyPhoto   PropertyPhoto  @relation(fields: [propertyPhotoId], references: [id], onDelete: Cascade)

  @@unique([occurrenceId, propertyPhotoId])
}

// ── Add-on Services ─────────────────────────────────────────────────────────

model OccurrenceAddon {
  id           String        @id @default(cuid())
  occurrenceId String
  occurrence   JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  tag          String?
  customLabel  String?
  price        Float
  createdById  String
  createdBy    User          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime      @default(now())

  @@index([occurrenceId])
}

// ── Occurrence Instructions ─────────────────────────────────────────────────

model OccurrenceInstruction {
  id           String        @id @default(cuid())
  occurrenceId String
  occurrence   JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  text         String
  isPreset     Boolean       @default(false)
  repeats      Boolean       @default(true)
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())

  @@index([occurrenceId])
}