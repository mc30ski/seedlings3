// PaymentMethod is no longer a DB enum — payment methods are fully
// configuration-driven via the PAYMENT_METHODS setting (a JSON taxonomy).
// Payment.method and ClientContact.preferredPaymentMethod are plain strings
// keyed to that taxonomy; writes are validated against it in payments.ts.

enum PaymentCommsMode {
  SERVER
  CLAIMER
}

model Payment {
  id String @id @default(cuid())

  // Accounting-system-agnostic ledger ID. See Checkout.ledgerId.
  ledgerId String? @unique

  occurrenceId String        @unique
  occurrence   JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  amountPaid Float
  // Free string keyed to the PAYMENT_METHODS taxonomy (Settings). Validated
  // at write time against the active taxonomy — see services/payments.ts
  // loadPaymentMethodKeys(). Not a DB enum so new methods are pure config.
  method     String
  note       String?

  platformFeePercent    Float? // % charged to contractor/unclassified
  platformFeeAmount     Float? // calculated on contractor splits: (splitAmount - expenses) * percent / 100
  businessMarginPercent Float? // % retained from employee/trainee splits
  businessMarginAmount  Float? // calculated on employee/trainee splits: (splitAmount - expenses) * percent / 100

  // Nullable: client self-reports via /pay/[token] without a logged-in user;
  // claimer on-site reports set this to themselves; admin direct-records sets
  // this to the admin.
  collectedById String?
  collectedBy   User?   @relation("PaymentCollector", fields: [collectedById], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Approval flow:
  //   confirmed=false means the payment was reported (by client or worker)
  //   but hasn't been verified against the actual bank/account yet. The
  //   occurrence stays PENDING_PAYMENT until confirmed=true. Admin-direct
  //   records are confirmed=true at creation (admin = approver).
  confirmed     Boolean   @default(false)
  confirmedAt   DateTime?
  confirmedById String?
  confirmedBy   User?     @relation("PaymentConfirmer", fields: [confirmedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  // True when the row was created via /pay/[token] client action OR a worker
  // on-site report — distinguished from an admin-direct record for audit + UI.
  selfReported Boolean @default(false)

  nextOccurrenceSkipReason String? // null = created successfully, "one_off" = expected, others = warning

  // Reconciliation against promisedPayouts (see JobOccurrence.promisedPayouts).
  // shortfallAmount > 0 when collected < promised: employees+trainees are
  // still paid their promised net, contractors share the shortfall pro-rata,
  // and the business absorbs the gap recorded here.
  // overageAmount  > 0 when collected > promised: workers paid promised net,
  // overage stays with the business.
  // Both are denormalized for fast reporting; never appear as a separate
  // accounting entry (cash-basis: it's already reflected in collected revenue
  // and labor cost).
  shortfallAmount Float @default(0)
  overageAmount   Float @default(0)

  // Processor fees: snapshotted from the PAYMENT_METHODS taxonomy at payment
  // time so changes to the fee schedule don't rewrite history. All nullable
  // — historical rows are treated as zero-fee at read time.
  //   processorFeePercent / processorFeeFixed = rate config used
  //   processorFeeAmount  = computed dollar fee for this transaction
  //   grossCharged        = what the client paid (matches amountPaid)
  //   netReceived         = grossCharged − processorFeeAmount
  processorFeePercent Float?
  processorFeeFixed   Float?
  processorFeeAmount  Float?
  grossCharged        Float?
  netReceived         Float?

  // Admin-adjusted amount at approval time (e.g. client wrote $100 but
  // actually paid $80). adjustedFromAmount preserves the originally-reported
  // value for audit.
  adjustedAt          DateTime?
  adjustedById        String?
  adjustedBy          User?     @relation("PaymentAdjuster", fields: [adjustedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  adjustedFromAmount  Float?

  // Write-off path: admin closes the books with collected=0 because client
  // never paid. Employees+trainees still get their promised net; contractors
  // get $0; full promised amount lands in shortfallAmount.
  writtenOff      Boolean   @default(false)
  writtenOffAt    DateTime?
  writtenOffById  String?
  writtenOffBy    User?     @relation("PaymentWriteOff", fields: [writtenOffById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  writeOffReason  String?

  splits PaymentSplit[]

  createdAt DateTime @default(now())

  @@index([collectedById, createdAt])
  @@index([method, createdAt])
  @@index([confirmed, createdAt])
  @@index([writtenOff, createdAt])
  @@index([processorFeeAmount, createdAt])
}

// DEPRECATED 2026-06-08 — kept for historical audit reference only.
//
// Under the wage-path GP model, a contractor in their GP period is paid
// like a W-2 employee: work-anchored, computed from completed
// occurrences each pay period (see services/exports.ts
// loadGpWorkAnchoredItems + gustoContractorsCsv). The app no longer
// writes to this table.
//
// Rows that already exist were created by the old export logic before
// the cutover. They remain in the database so:
//   • Pre-cutover periods' QB Contract Labor reconciliation still works
//   • Historical "what was paid out via Gusto" lookups still find the
//     advance amount (informational only — Gusto is the system of
//     record for actual contractor payments going forward)
//   • The full-DB JSON export still includes them
//
// The double-payment-prevention question ("was this contractor already
// paid for this work?") is now answered by a pure derivation:
// occurrence.completedAt ∈ user.guaranteedPayoutUntil window. See
// payments.ts fetchAdvanceFlagsByUser. Advance row existence is no
// longer consulted by new code.
//
// DO NOT write new rows to this table. New code paths producing
// contractor payments must route through the wage-path computation in
// loadGpWorkAnchoredItems instead.
model GuaranteedPayoutAdvance {
  id String @id @default(cuid())

  // Accounting-system-agnostic ledger ID. See Checkout.ledgerId.
  ledgerId String? @unique

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  occurrenceId String
  occurrence   JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // The contractor's promised net at advance time — computed via the same
  // computeBreakdown formula used for promisedPayouts snapshots. Stored
  // here verbatim so a later price/expense edit doesn't change history.
  amount Float

  // When the GP export run that included this advance emitted the row.
  // Used as the PaymentSplit.guaranteedPayoutPaidAt timestamp when the
  // client eventually pays.
  exportedAt DateTime @default(now())

  // Operator who ran the export. Useful for the audit trail; nullable so
  // a deleted user doesn't break advance rows.
  exportedByUserId String?
  exportedBy       User?   @relation("AdvanceExporter", fields: [exportedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@unique([userId, occurrenceId])
  @@index([userId, exportedAt])
  @@index([occurrenceId])
}

model PaymentSplit {
  id String @id @default(cuid())

  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // `amount` is the worker's final net payout (gross − fee + topUp).
  // The breakdown columns below are populated for transparency/reporting:
  //   grossAmount  = N × splitPercent  (worker's share before fee)
  //   ratePercent  = the fee/margin rate applied to THIS worker
  //   feeAmount    = grossAmount × ratePercent / 100
  //   netAmount    = grossAmount − feeAmount  (pre-topUp)
  //   topUpAmount  = extra the business paid out to make an employee/trainee
  //                  whole when the client underpaid
  // All nullable on historical rows; populated on rows created after the
  // 20260518_payment_reconciliation migration.
  amount      Float
  grossAmount Float?
  ratePercent Float?
  feeAmount   Float?
  netAmount   Float?
  topUpAmount Float  @default(0)

  // Stamped at write time when the split's user is the LLC owner. Excluded
  // from Gusto/payroll exports — the owner takes a draw, not a paycheck.
  ownerEarnings Boolean @default(false)

  // Guaranteed-payout reconciliation. Set when this split's user was
  // in their GP period at the moment of work completion — i.e. the
  // work was paid on the wage-path Gusto run for the completion week
  // (loadGpWorkAnchoredItems), not via this client-payment split. The
  // value is the occurrence's `completedAt` (the wage-path anchor).
  //
  // When the client later pays and this row is generated, payroll +
  // QB exports skip flagged rows so the contractor isn't paid twice.
  // The flag is derived at split-creation time by
  // services/payments.ts fetchAdvanceFlagsByUser — see that function
  // for the derivation rule.
  guaranteedPayoutPaidAt DateTime?

  createdAt DateTime @default(now())

  @@unique([paymentId, userId])
  @@index([userId, createdAt])
  @@index([ownerEarnings, createdAt])
  @@index([guaranteedPayoutPaidAt])
}

model Expense {
  id String @id @default(cuid())

  occurrenceId String
  occurrence   JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Restrict, onUpdate: Cascade)

  cost        Float
  description String

  // 1:1 link to the BusinessExpense (tax ledger) row. Every Expense added on
  // a job in MVP-step-2 onward gets a paired BusinessExpense — workers buy on
  // the company card, so per-job spend IS a business expense.
  businessExpenseId String?          @unique
  businessExpense   BusinessExpense? @relation(fields: [businessExpenseId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // Back-relation: when this Expense was created by consuming inventory
  // (MVP-step-3), the SupplyHold owns the link via SupplyHold.expenseId.
  // No BusinessExpense is paired in this case — the BE was already recorded
  // at purchase time, and double-recording would inflate tax-ledger totals.
  supplyHold SupplyHold?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([occurrenceId])
  @@index([createdById])
}

// BusinessExpense is the canonical Accounting ledger row. Despite the name,
// it now stores three KINDS of money entries — discriminated by `type`:
//   EXPENSE              — operating cash-out (default; backward-compat)
//   CAPITAL_CONTRIBUTION — owner money INTO the business (equity)
//   OWNER_DRAW           — owner money OUT of the business (equity)
//
// All three share the same shape (date, amount, vendor, description,
// receipt, recurrence) so the UI, receipt anchor, and recurrence engine
// work identically for all of them. Surfaces that semantically mean
// "expenses only" must filter `type = EXPENSE` explicitly:
//   - vs-revenue (P&L)
//   - summary
//   - qbExpensesCsv (QB import — Schedule C lines)
//   - Schedule C CSV export
// Surfaces that span all types (full bookkeeping list, due-soon recurrence
// suggestions, receipt routes) do NOT filter by type.
//
// Three creation paths, all land here regardless of type:
//   1. Freestanding — admin types into Add Entry. The Type picker chooses
//      EXPENSE / CAPITAL_CONTRIBUTION / OWNER_DRAW.
//   2. Job-paired — worker logs an Expense on a JobOccurrence (always
//      EXPENSE). Linked via Expense.businessExpenseId.
//   3. Supply-paired — SupplyPurchase creates a BE at buy time (always
//      EXPENSE). Linked via SupplyPurchase.businessExpenseId.
//
// Export shape:
//   - Schedule C CSV (Accounting tab "Export" button) — EXPENSE only, line
//     numbers from EXPENSE_CATEGORIES taxonomy.
//   - qb-expenses.csv (Exports tab) — EXPENSE + processor fees.
//   - qb-equity.csv (Exports tab) — CAPITAL_CONTRIBUTION + OWNER_DRAW with
//     standard equity account names ("Owner's Investment" / "Owner's Draw").
//
// Tax-export integrity: only raw cash-flow fields (cost, date, vendor) flow
// into any export — no derived margin/shortfall fields ever appear.
model BusinessExpense {
  id String @id @default(cuid())

  // Accounting-system-agnostic ledger ID. See Checkout.ledgerId.
  // One ledgerId covers EXPENSE, OWNER_DRAW, and CAPITAL_CONTRIBUTION
  // uniformly — the type discriminator routes which QB export the row
  // ends up in, but the ID format is identical.
  ledgerId String? @unique

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Discriminator. Default is EXPENSE so existing rows keep their meaning;
  // see EntryType enum doc for the full picture.
  type EntryType @default(EXPENSE)

  date          DateTime
  cost          Float
  description   String
  // Schedule C category — meaningful only for type = EXPENSE. For
  // CAPITAL_CONTRIBUTION / OWNER_DRAW this stays null (those are equity
  // accounts, not Schedule C lines).
  category      String?
  vendor        String?
  invoiceNumber String?
  notes         String?
  // Free-text record of which account / instrument the payment came from
  // (e.g. "Chase business card", "Owner cash", "Bluevine checking"). Pure
  // operator note — not categorized, never feeds tax line items. Useful for
  // reconciling against bank/card statements at month-end.
  paymentFrom   String?

  // Optional link to a piece of equipment — useful for capital purchases
  // (e.g. "$8K rider mower" categorized as Depreciation gets linked to its
  // Equipment row so we can track per-equipment lifetime cost later).
  equipmentId String?
  equipment   Equipment? @relation(fields: [equipmentId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // Optional link to a job occurrence — set when the expense was incurred for
  // a specific job (worker buys gas on the company card). The corresponding
  // per-Job Expense row drives payout reduction; this row is the tax ledger
  // entry. Linked 1:1 via Expense.businessExpenseId.
  occurrenceId String?
  occurrence   JobOccurrence? @relation(fields: [occurrenceId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  expense      Expense?

  // Back-relation: when this BE was created by an inventory purchase
  // (MVP-step-3), the SupplyPurchase owns the link via
  // SupplyPurchase.businessExpenseId. Allows the tax-ledger UI to surface a
  // "Supply: Mulch ×10" badge and link back to the Supplies tab.
  supplyPurchase SupplyPurchase?

  // Optional receipt photo. Stored in the seedlings-receipts R2 bucket; the
  // R2 key is the canonical reference. Same anchor for all 3 expense
  // sources (freestanding BE, job-Expense pair, supply-purchase pair).
  receiptR2Key       String?
  receiptFileName    String?
  receiptContentType String?
  receiptUploadedAt  DateTime?

  // Optional cadence flag for recurring expenses (e.g. monthly software
  // subscriptions). Null = one-off. The most recent row in a group keyed
  // by (description, vendor) drives "due to record" suggestions.
  recurrence ExpenseRecurrence?

  // When set, the next-expected date for the series is computed from this
  // date instead of `date + cadence`. Used by the "Skip" button on the Due
  // to record panel: skipping the May invoice sets this to the May expected
  // date, so the next suggestion is one cadence later.
  recurrenceSkippedUntil DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([category])
  @@index([createdById])
  @@index([equipmentId])
  @@index([occurrenceId])
  @@index([type])
}

