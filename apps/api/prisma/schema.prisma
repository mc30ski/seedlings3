// ── Client-initiated change requests on a scheduled occurrence ──────────────
// Clients can request a reschedule (with proposed date) or skip a single
// occurrence. Admins approve/deny — approval applies the change.
enum ChangeRequestKind {
  RESCHEDULE
  SKIP
}

enum ChangeRequestStatus {
  PENDING
  APPROVED
  DENIED
  CANCELED
}

model OccurrenceChangeRequest {
  id              String              @id @default(cuid())
  occurrenceId    String
  occurrence      JobOccurrence       @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  requestedById   String
  requestedBy     User                @relation("ChangeRequestRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  kind            ChangeRequestKind
  status          ChangeRequestStatus @default(PENDING)
  proposedStartAt DateTime?
  comment         String?
  resolvedById    String?
  resolvedBy      User?               @relation("ChangeRequestResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolvedAt      DateTime?
  resolutionNote  String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([occurrenceId])
  @@index([requestedById])
  @@index([status])
}

// ── Supplies (MVP-step-3) ─────────────────────────────────────────────────────
//
// Inventory-tracked consumables. Decoupled from job-Expense so we can record
// the tax deduction at PURCHASE time (cash-method accounting) but charge the
// payout deduction at CONSUMPTION time, with optional markup.
//
//   Supply           = catalog row (one per SKU), tracks onHand
//   SupplyPurchase   = a buy event, paired 1:1 with a BusinessExpense (tax)
//   SupplyHold       = a consumption against an occurrence; ACTIVE reserves
//                      units, CONSUMED draws them down on completion
//   SupplyAdjustment = manual count corrections (no tax effect)

model Supply {
  id String @id @default(cuid())

  name          String
  description   String?
  unit          String // "bag", "spool", "lb"
  // For future UPC-scan add-flow. Nullable; not unique because the same
  // SKU could legitimately be entered twice with different display names.
  upc           String?
  // Schedule C category for the BusinessExpense paired with each purchase.
  // Defaults to "Supplies"; can be overridden per supply (e.g. "Car and
  // truck expenses" if you ever want to track fuel as inventory).
  category      String  @default("Supplies")
  // Reference businessCost — typically updated to the most recent
  // SupplyPurchase.unitCost. Display-only / default for new purchases.
  businessCost  Float   @default(0)
  // Per-unit charge to the job's payout when consumed. May exceed
  // businessCost — the difference is implicit business margin (similar to
  // platform fee / employee margin). Snapshot at hold time so retroactive
  // edits don't reprice existing holds.
  jobPayoutCost Float   @default(0)
  // Physical units in stock. Available = onHand − Σ(active holds), computed
  // at query time.
  onHand        Int     @default(0)

  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Restrict)

  purchases   SupplyPurchase[]
  holds       SupplyHold[]
  adjustments SupplyAdjustment[]

  @@index([archivedAt])
  @@index([upc])
  @@index([name])
}

model SupplyPurchase {
  id String @id @default(cuid())

  supplyId String
  supply   Supply @relation(fields: [supplyId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  quantity      Int
  unitCost      Float // per-unit cost at this purchase (snapshot)
  totalCost     Float // quantity × unitCost (denormalized for export)
  date          DateTime @default(now())
  vendor        String?
  invoiceNumber String?
  notes         String?

  // 1:1 link to the tax-ledger row created at the same time. Same dual-write
  // pattern as job Expense ↔ BusinessExpense in step-2. Restrict (not
  // Cascade): deleting the BE while a SupplyPurchase is linked would orphan
  // inventory; the BE-delete handler must reverse inventory and remove the
  // SupplyPurchase first.
  businessExpenseId String          @unique
  businessExpense   BusinessExpense @relation(fields: [businessExpenseId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([supplyId, date])
  @@index([date])
}

model SupplyHold {
  id String @id @default(cuid())

  supplyId String
  supply   Supply @relation(fields: [supplyId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  occurrenceId String
  occurrence   JobOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  quantity      Int
  jobPayoutCost Float // per-unit charge snapshot at hold time
  status        SupplyHoldStatus @default(ACTIVE)

  // 1:1 link to the per-job Expense row that drives payout deduction.
  // No paired BusinessExpense — the BE was created at purchase time;
  // recording another at consumption would double-count for taxes.
  expenseId String?  @unique
  expense   Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())
  consumedAt  DateTime?
  releasedAt  DateTime?
  updatedAt   DateTime  @updatedAt

  @@index([supplyId, status])
  @@index([occurrenceId])
  @@index([status])
}

model SupplyAdjustment {
  id String @id @default(cuid())

  supplyId String
  supply   Supply @relation(fields: [supplyId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  delta  Int // +N or −N units
  reason String

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())

  @@index([supplyId, createdAt])
}

enum SupplyHoldStatus {
  ACTIVE
  CONSUMED
  RELEASED
}

enum ExpenseRecurrence {
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

// ─────────────────────────────────────────────────────────────────────────────
// Groups (crews)
//
// A Group is a saved roster of workers + observers led by a single claimer.
// Admins manage groups via Admin → Directory → Groups. A user can be in
// multiple groups. At job-assignment time the group is *materialized* into
// individual JobOccurrenceAssignee rows — the group is a template, not a
// live join. Mid-flight group edits never propagate to in-flight occurrences;
// see the lock check in services/groups.ts.
// ─────────────────────────────────────────────────────────────────────────────
model Group {
  id          String  @id @default(cuid())
  name        String
  description String? @db.Text

  claimerUserId String
  claimer       User   @relation("GroupClaimer", fields: [claimerUserId], references: [id], onDelete: Restrict)

  members            GroupMember[]
  preferredEquipment GroupPreferredEquipment[]

  // Back-relations
  occurrences JobOccurrence[] @relation("OccurrenceGroup")
  checkouts   Checkout[]
  defaultForJobs Job[]        @relation("JobDefaultGroup")

  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([claimerUserId])
  @@index([archivedAt])
}

model GroupMember {
  id      String @id @default(cuid())
  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  // "worker" (null in JobOccurrenceAssignee terms) or "observer"
  role String @default("worker")

  // Per-member share of group equipment costs. Null = even-split among
  // workers (observers always excluded). When any are non-null, every worker
  // in the group must have a value and they must sum to exactly 100.
  equipmentCostPercent Float?

  createdAt DateTime @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

// Preferred equipment + collections for a group. Display-only — never
// auto-reserves. Surfaces as a "Group preferred" panel on occurrences
// claimed by the group. Exactly one of equipmentId / equipmentCollectionId
// must be set (enforced in app code; no Prisma CHECK constraint).
model GroupPreferredEquipment {
  id      String @id @default(cuid())
  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  equipmentId           String?
  equipment             Equipment?           @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  equipmentCollectionId String?
  equipmentCollection   EquipmentCollection? @relation(fields: [equipmentCollectionId], references: [id], onDelete: Cascade)

  sortOrder Int      @default(100)
  createdAt DateTime @default(now())

  @@index([groupId, sortOrder])
  @@index([equipmentId])
  @@index([equipmentCollectionId])
}

// Company-level documents (Articles of Organization, Insurance certs, etc.).
// `type` is a string key into the DOCUMENT_TYPES setting taxonomy. A type can
// be flagged singleton in the taxonomy — enforced at the API layer.
// `currentVersionId` points at one of this doc's CompanyDocumentVersion rows.
model CompanyDocument {
  id          String  @id @default(cuid())
  type        String
  title       String
  description String?
  expiresAt   DateTime?
  // When true, Admins cannot see this document; only Super.
  adminHidden Boolean @default(false)

  // Pointer to the currently-active version. Nullable while doc has no
  // uploaded version yet (e.g., metadata created but file not yet PUT).
  currentVersionId String?                  @unique
  currentVersion   CompanyDocumentVersion?  @relation("CompanyDocCurrent", fields: [currentVersionId], references: [id], onDelete: SetNull)

  versions CompanyDocumentVersion[] @relation("CompanyDocVersions")

  createdById String
  createdBy   User   @relation("CompanyDocCreator", fields: [createdById], references: [id], onDelete: Restrict)

  archivedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([type, archivedAt])
  @@index([expiresAt])
}

model CompanyDocumentVersion {
  id         String @id @default(cuid())
  documentId String
  document   CompanyDocument @relation("CompanyDocVersions", fields: [documentId], references: [id], onDelete: Cascade)

  r2Key            String  @unique
  contentType      String
  originalFilename String
  sizeBytes        Int

  uploadedById String
  uploadedBy   User   @relation("CompanyDocVersionUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  uploadedAt   DateTime @default(now())

  // Back-relation for the currentVersion pointer on CompanyDocument.
  currentForDocument CompanyDocument? @relation("CompanyDocCurrent")

  @@index([documentId, uploadedAt])
}
