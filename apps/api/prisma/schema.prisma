enum JobKind {
  ENTIRE_SITE
  SINGLE_ADDRESS
}

enum JobStatus {
  PROPOSED
  ACCEPTED
  PAUSED
  ARCHIVED
}

enum Cadence {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum JobOccurrenceStatus {
  SCHEDULED
  IN_PROGRESS
  PAUSED
  COMPLETED
  PENDING_PAYMENT
  CLOSED
  CANCELED
  ARCHIVED
  PROPOSAL_SUBMITTED
  ACCEPTED
  REJECTED
}

enum OccurrenceWorkflow {
  STANDARD
  ONE_OFF
  ESTIMATE
  TASK
  REMINDER
  EVENT
  FOLLOWUP
  ANNOUNCEMENT
}

enum JobOccurrenceSource {
  GENERATED
  MANUAL
}

model Job {
  id String @id @default(cuid())

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  kind   JobKind   @default(SINGLE_ADDRESS) // REQUIRED
  status JobStatus @default(PROPOSED)

  frequencyDays    Int?
  description      String?
  notes            String?
  defaultPrice     Float?
  estimatedMinutes Int?

  // Default guidance description, seeded onto new occurrences as their
  // editable JobOccurrence.guidanceNote (mirrors the default photo set).
  guidanceNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Default crew. EITHER set `defaultGroupId` (and the JobAssigneeDefault
  // list stays empty) OR populate JobAssigneeDefault rows — not both. The
  // mode is enforced in app code (services/jobs.ts). When defaultGroupId
  // is set, new occurrences materialize the group's full roster.
  defaultGroupId   String?
  defaultGroup     Group?  @relation("JobDefaultGroup", fields: [defaultGroupId], references: [id], onDelete: SetNull)

  contacts JobContact[]
  clients  JobClient[]

  schedule               JobSchedule?
  occurrences            JobOccurrence[]
  defaultAssignees       JobAssigneeDefault[]
  defaultPropertyPhotos  JobPropertyPhoto[]
  followups              FollowupJob[]
  recommendedCollections JobRecommendedCollection[]

  @@index([defaultGroupId])
}

model JobContact {
  id String @id @default(cuid())

  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  clientContactId String
  clientContact   ClientContact @relation(fields: [clientContactId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  role   String // "decision_maker" | "on_site" | "notify_only"
  notify Boolean @default(true)

  @@index([jobId])
  @@index([clientContactId])
}

model JobClient {
  id String @id @default(cuid())

  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  role  String // "owner" | "payer" | "point_of_contact"
  share Float? // optional split %

  @@index([jobId])
  @@index([clientId])
}

model JobSchedule {
  id String @id @default(cuid())

  jobId String @unique
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  autoRenew Boolean @default(false)

  cadence  Cadence?
  interval Int? // every N weeks/months (simple)

  dayOfWeek  Int? // 0-6 for weekly-ish schedules
  dayOfMonth Int? // 1-31 for monthly-ish schedules

  preferredStartHour Int?
  preferredEndHour   Int?

  horizonDays    Int       @default(21)
  nextGenerateAt DateTime?
  active         Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JobOccurrence {
  id String @id @default(cuid())

  jobId String?
  job   Job?    @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  kind JobKind? // Copied from Job.kind on creation; null for tasks

  title String? // Short title for tasks; optional for job occurrences

  startAt DateTime?
  endAt   DateTime?

  status   JobOccurrenceStatus @default(SCHEDULED)
  source   JobOccurrenceSource @default(GENERATED)
  workflow OccurrenceWorkflow  @default(STANDARD)

  jobType                    String? // Legacy/custom free-text job type
  jobTags                    String? // JSON array of tags, e.g. ["MOW","TRIM","EDGE","BLOW"]
  notes                      String?
  price                      Float?
  estimatedMinutes           Int?
  frequencyDays              Int? // Overrides Job.frequencyDays when set
  proposalAmount             Float?
  proposalNotes              String?
  rejectionReason            String?
  generatedEstimate          String? // AI-generated estimate message for client
  generatedEstimateBreakdown String? // AI-generated internal cost breakdown for business
  // Light estimate fields (used when jobId is null and workflow is ESTIMATE)
  contactName                String?
  contactPhone               String?
  contactEmail               String?
  estimateAddress            String?

  isOneOff          Boolean @default(false) // @deprecated — use workflow
  isTentative       Boolean @default(false)
  isEstimate        Boolean @default(false) // @deprecated — use workflow
  isAdminOnly       Boolean @default(false)
  isClientConfirmed Boolean @default(false)
  isHighPriority    Boolean @default(false)
  pinnedNote        String?
  pinnedNoteRepeats Boolean @default(true)

  // Optional free-text description for the occurrence's guidance, shown
  // alongside the guidance photos. Carried forward to the next occurrence
  // on close, same as the photos (see payments.ts close→next block).
  guidanceNote String?

  // Payment-request flow (set when occurrence transitions to PENDING_PAYMENT).
  // The token is the URL slug for the public /pay/[token] page; createdAt
  // anchors the expiry (controlled by PAYMENT_REQUEST_TOKEN_EXPIRY_HOURS).
  paymentRequestToken          String?   @unique
  paymentRequestTokenCreatedAt DateTime?
  // Stamped when the Request Payment path is committed: either the worker
  // tapped the button (CLAIMER mode) or sendForOccurrence fired
  // (SERVER mode). Drives the "either-or" workflow on the job card —
  // once set, Accept Payment is hidden and the worker either re-sends
  // or cancels. Cleared by paymentRequests.cancelPaymentRequest.
  paymentRequestSentAt DateTime?
  // Per-worker percentage allocation locked in by the claimer at completion
  // time. Stored as JSON: [{ userId: "...", percent: 50 }, ...]. Drives the
  // PaymentSplit math; survives overpayments (extras distribute pro-rata).
  // Null = even-split fallback applies.
  completionSplits Json?

  // Immutable snapshot taken when the occurrence is completed with splits.
  // Locks in what each worker is OWED regardless of what the client ends up
  // paying. Used at approval time to top employees/trainees up to their
  // promised net even when the client underpays.
  // Shape: [{ userId, workerType, splitPercent, gross, ratePercent, fee, net }]
  promisedPayouts Json?

  // Latest payment-rejection metadata (denormalized from the audit log so
  // the job card can display the reason without a per-card query). Set by
  // payments.rejectPayment when admin rejects a self-reported payment.
  // Cleared when a payment is approved (occurrence transitions to CLOSED)
  // or the occurrence is reverted to SCHEDULED.
  lastPaymentRejectionReason String?
  lastPaymentRejectedAt      DateTime?

  // Latest payment-revert metadata. Set when admin reverts an already-
  // approved payment (CLOSED → PENDING_PAYMENT) on the Services tab.
  // Same display semantics as the rejection fields above; cleared on the
  // next approved payment.
  lastPaymentRevertReason String?
  lastPaymentRevertedAt   DateTime?

  startedAt     DateTime?
  completedAt   DateTime?
  pausedAt      DateTime?
  totalPausedMs Int       @default(0)

  // Payroll-hours approval. Independent of the payment-flow status — a job
  // can be CLOSED (client paid) while hoursApprovedAt is still null. The
  // Gusto W-2 / contractors exports filter on `hoursApprovedAt IS NOT NULL`,
  // so unapproved rows are excluded from payroll until reviewed.
  //
  // Auto-approve rule: when a worker hits Complete, if the variance between
  // actual hours and adjusted estimate is within the warning threshold
  // (currently 30%, matching the visual warning on the card), hoursApprovedAt
  // is stamped immediately. Outside the threshold, it stays null and the
  // occurrence shows an "Hours awaiting approval" chip until an admin/super
  // explicitly approves (or adjusts startedAt/completedAt back into range).
  hoursApprovedAt    DateTime?
  hoursApprovedById  String?
  hoursApprovedBy    User?     @relation("HoursApprover", fields: [hoursApprovedById], references: [id], onDelete: SetNull)

  startLat    Float?
  startLng    Float?
  completeLat Float?
  completeLng Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  linkedOccurrenceId String?
  linkedOccurrence   JobOccurrence?  @relation("TaskLink", fields: [linkedOccurrenceId], references: [id], onDelete: SetNull)
  linkedFromTasks    JobOccurrence[] @relation("TaskLink")

  linkGroupId String?

  // Set when admin attached a Group (crew) or the claimer claimed for a group.
  // Members are materialized into `assignees` at attach/claim time — this
  // column is the back-link so we can render "Group: Alpha (5)" and enforce
  // the group-vs-individual exclusivity rule.
  assignedGroupId String?
  assignedGroup   Group?  @relation("OccurrenceGroup", fields: [assignedGroupId], references: [id], onDelete: SetNull)

  assignees        JobOccurrenceAssignee[]
  payment          Payment?
  guaranteedPayoutAdvances GuaranteedPayoutAdvance[]
  expenses         Expense[]
  businessExpenses BusinessExpense[]
  supplyHolds      SupplyHold[]
  addons           OccurrenceAddon[]
  instructions     OccurrenceInstruction[]
  photos           JobOccurrencePhoto[]
  propertyPhotos   OccurrencePropertyPhoto[]
  pins             PinnedOccurrence[]
  likes            LikedOccurrence[]
  reminders        Reminder[]
  comments         OccurrenceComment[]
  followupClients  FollowupClient[]
  followupJobs     FollowupJob[]
  changeRequests   OccurrenceChangeRequest[]

  @@index([linkGroupId])
  @@index([assignedGroupId])
  @@index([jobId, status])
  @@index([startAt])
  @@index([kind])
  @@index([hoursApprovedAt])
}

