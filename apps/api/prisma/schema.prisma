generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum Role {
  WORKER
  ADMIN
  SUPER
}

enum EquipmentStatus {
  AVAILABLE
  RESERVED
  CHECKED_OUT
  MAINTENANCE
  RETIRED
}

enum AuditScope {
  USER
  EQUIPMENT
  CLIENT
  JOB
  PROPERTY
  SETTING
  NOTIFICATION
  DOCUMENT
  TIMELINE
  BANNER
  PAYMENT
  EXPORT
  WORKDAY
  // add more scopes as you expand the schema
}

enum AuditVerb {
  APPROVED
  ROLE_ASSIGNED
  ROLE_REMOVED
  CREATED
  UPDATED
  RETIRED
  UNRETIRED
  DELETED
  CHECKED_OUT
  RELEASED
  MAINTENANCE_START
  MAINTENANCE_END
  RESERVED
  RESERVATION_CANCELLED
  RETURNED
  FORCE_RELEASED
  PRIMARY_CONTACT_SET
  SETTING_UPDATED
  WORKER_TYPE_SET
  INSURANCE_UPLOADED
  CONTRACTOR_AGREED
  W9_COLLECTED
  SENT
  VERSION_ADDED
  VERSION_RESTORED
  VERSION_DELETED
  VIEWED
  DOWNLOADED
  COMPLETED
  SELF_REPORTED
  REJECTED
  REQUEST_SENT
  TOKEN_ACCESSED
  WRITTEN_OFF
  ADJUSTED
  OWNER_EARNINGS_RECORDED
  FEE_APPLIED
  PAYMENT_METHOD_UPDATED
  GUARANTEED_PAYOUT_STARTED
  GUARANTEED_PAYOUT_ENDED
  // add new verbs as needed
}

enum WorkerType {
  EMPLOYEE
  CONTRACTOR
  TRAINEE
}

model User {
  id          String  @id @default(cuid())
  clerkUserId String  @unique
  email       String?
  phone       String?
  firstName   String?
  lastName    String?
  displayName String?
  isApproved  Boolean @default(false)

  workerType           WorkerType?
  homeBaseAddress      String?
  availableDays        String? // JSON array of day numbers, e.g. "[1,2,3,4,5]" (0=Sun,6=Sat)
  availableHoursPerDay Float? // default 4 if null

  // Hourly pay rate used for the Reconcile → Payroll export. Set per
  // worker so the Payroll card can render `hours × hourlyWage` =
  // regular wages, and the operator types `additionalEarnings` (the
  // delta between target gross and regular wages) into Gusto.
  // Defaults to 0 so contractors (paid lump-sum) and unconfigured
  // workers render predictably — Regular Wages = 0, Additional
  // Earnings absorbs the full target gross.
  hourlyWage           Decimal     @default(0) @db.Decimal(10, 2)

  // Privilege overrides. Null = follow workerType default (resolved in app
  // code via DEFAULTS_BY_WORKERTYPE). True/false = explicit override.
  //
  //   canPullInventory  defaults: TRAINEE=false, CONTRACTOR/EMPLOYEE=true
  //   canChargeBusinessExpenses  defaults: false everywhere (granted explicitly)
  //
  // Admin/Super always have both effectively true regardless of these
  // columns — the role guard wins.
  canPullInventory          Boolean?
  canChargeBusinessExpenses Boolean?

  insuranceCertR2Key       String?
  insuranceCertFileName    String?
  insuranceCertContentType String?
  insuranceExpiresAt       DateTime?
  contractorAgreedAt       DateTime?
  w9Collected              Boolean   @default(false)
  w9CollectedAt            DateTime?

  // Contractor onboarding "guaranteed payout period." When
  // `guaranteedPayoutUntil` is in the future, contractor payroll for this
  // worker is work-anchored (paid for completed jobs regardless of client
  // payment timing) instead of payment-anchored. Auto-expires when the
  // date passes — no further action required (a daily cron writes the
  // GUARANTEED_PAYOUT_ENDED audit row for natural expirations and clears
  // these columns).
  // `guaranteedPayoutStartedAt` records when the current period began for
  // UI display ("X days left of N"). Both null = standard contingent-
  // payment terms apply. See onboarding addendum for the contractual
  // position; reclassification-risk discussion in user memo.
  // NOTE: this concept is distinct from the "made whole" terminology used
  // in payments.ts (which refers to employees being made whole when a
  // client underpays). That's about AMOUNT; this is about TIMING.
  //
  // `guaranteedPayoutHistory` is an append-only JSON array of past periods:
  //   [{ startedAt: ISO, endedAt: ISO, endedEarly: bool, endedActorUserId: string|null }]
  // Written on early-end (route) and natural expiration (cron) so split-
  // reconciliation and work-anchored payroll exports can answer "was the
  // contractor in a GP period at this occurrence's completedAt?" even
  // after the active columns have been cleared. Empty array on a fresh
  // user; never NULL once initialized.
  guaranteedPayoutUntil      DateTime?
  guaranteedPayoutStartedAt  DateTime?
  guaranteedPayoutHistory    Json      @default("[]")

  // LLC-owner flag. At most one user may have this set to true (enforced via
  // partial unique index in the migration). Additive to ADMIN/SUPER role —
  // does not replace it. The owner participates in jobs like any worker;
  // their PaymentSplit rows get ownerEarnings=true, which the Gusto/payroll
  // exports filter out (the owner takes a draw, not a paycheck).
  isOwner                  Boolean   @default(false)

  // Per-user override for payment-request delivery channel.
  // null = use the org-wide DEFAULT_PAYMENT_COMMUNICATIONS_MODE setting.
  paymentCommsMode PaymentCommsMode?

  roles          UserRole[]
  checkouts      Checkout[]
  checkoutSplits CheckoutSplit[]
  auditEvents    AuditEvent[]    @relation("AuditActor")

  // Groups
  groupsClaimed    Group[]       @relation("GroupClaimer")
  groupMemberships GroupMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobDefaultAssignments    JobAssigneeDefault[]
  jobOccurrenceAssignments JobOccurrenceAssignee[]
  jobAssignmentAuditActor  JobOccurrenceAssignee[] @relation("JobAssignActor")

  paymentsCollected       Payment[]       @relation("PaymentCollector")
  paymentsConfirmed       Payment[]       @relation("PaymentConfirmer")
  paymentsAdjusted        Payment[]       @relation("PaymentAdjuster")
  paymentsWrittenOff      Payment[]       @relation("PaymentWriteOff")
  paymentSplits           PaymentSplit[]
  guaranteedPayoutAdvances   GuaranteedPayoutAdvance[]
  guaranteedPayoutAdvancesExported GuaranteedPayoutAdvance[] @relation("AdvanceExporter")
  expenses                Expense[]
  photos                  JobOccurrencePhoto[]
  settingsUpdated         Setting[]
  pinnedOccurrences       PinnedOccurrence[]
  likedOccurrences        LikedOccurrence[]
  reminders               Reminder[]
  calendarFeedTokens      CalendarFeedToken[]
  occurrenceComments      OccurrenceComment[]
  propertyPhotosUploaded  PropertyPhoto[]
  equipmentPhotosUploaded EquipmentPhoto[]
  occurrenceAddons        OccurrenceAddon[]
  pinnedEquipment         PinnedEquipment[]
  likedEquipment          LikedEquipment[]
  businessExpenses        BusinessExpense[]
  changeRequestsCreated   OccurrenceChangeRequest[] @relation("ChangeRequestRequester")
  changeRequestsResolved  OccurrenceChangeRequest[] @relation("ChangeRequestResolver")
  hoursApproved           JobOccurrence[]           @relation("HoursApprover")
  pushSubscriptions       PushSubscription[]

  suppliesCreated          Supply[]
  supplyPurchasesCreated   SupplyPurchase[]
  supplyHoldsCreated       SupplyHold[]
  supplyAdjustmentsCreated SupplyAdjustment[]

  companyDocumentsCreated  CompanyDocument[]        @relation("CompanyDocCreator")
  documentVersionsUploaded CompanyDocumentVersion[] @relation("CompanyDocVersionUploader")

  timelineEventsCreated    TimelineEvent[]          @relation("TimelineEventCreator")

  bannersCreated     BannerNotification[] @relation("BannerCreator")
  bannerRecipients   BannerRecipient[]
  bannerDismissals   BannerDismissal[]

  // Workday tracking — per-worker daily clock-in/out for payroll. See
  // WorkerWorkday model. `workdaysApproved` is the back-relation for the
  // admin-approval phase (built later; the field exists now so the schema
  // doesn't need a follow-up migration).
  workdays           WorkerWorkday[] @relation("WorkdayWorker")
  workdaysApproved   WorkerWorkday[] @relation("WorkdayApprover")
}

model NotificationTemplate {
  id        String   @id @default(cuid())
  name      String
  title     String?
  body      String   @db.Text
  sortOrder Int      @default(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder, name])
}

model PushSubscription {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint   String    @unique
  p256dh     String
  auth       String
  userAgent  String?
  label      String?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  @@index([userId])
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  role   Role

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
}

model Equipment {
  id        String          @id @default(uuid())
  qrSlug    String?         @unique
  status    EquipmentStatus @default(AVAILABLE)
  type      String?
  brand     String?
  model     String?
  shortDesc String?
  longDesc  String?
  energy    String?
  features  String?
  condition String?
  issues    String?
  age       String?

  dailyRate         Float?

  // Per-job-with-daily-cap billing knob for contractors.
  //   NULL  → legacy flat-daily billing (rentalCost = rentalDays × dailyRate).
  //   N > 0 → per-job rate is (dailyRate / N), capped per ET calendar day at
  //           dailyRate. Contractors pay per formal-crew (or solo) job
  //           completed while the equipment was checked out. The "Right Now"
  //           cap protects them from overpaying on heavy-volume days.
  // Admin opts a piece into the new model by setting this column. See
  // services/equipment.ts computeRentalCost and the memo at
  // memory/feature_per_job_equipment_billing.md.
  equivalentJobs    Int?

  requiresInsurance Boolean @default(false)

  checkouts        Checkout[]
  photos           EquipmentPhoto[]
  pins             PinnedEquipment[]
  likes            LikedEquipment[]
  instructions     EquipmentInstruction[]
  collections      EquipmentCollectionItem[]
  businessExpenses BusinessExpense[]
  groupPreferences GroupPreferredEquipment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  retiredAt DateTime?
}

model EquipmentPhoto {
  id           String    @id @default(cuid())
  equipmentId  String
  equipment    Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  r2Key        String
  fileName     String?
  contentType  String?
  description  String?
  sortOrder    Int       @default(0)
  uploadedById String
  uploadedBy   User      @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  createdAt    DateTime  @default(now())

  @@index([equipmentId])
}

model Checkout {
  id           String    @id @default(cuid())
  // Accounting-system-agnostic ledger ID — SLC-YYMMDD-XXXX. Stamped at row
  // creation, used as the QuickBooks JournalNo. Nullable in the schema for
  // the brief backfill window; every row carries a value post-backfill.
  ledgerId     String?   @unique
  equipmentId  String
  userId       String
  reservedAt   DateTime  @default(now())
  checkedOutAt DateTime?
  releasedAt   DateTime?
  rentalDays   Int?
  rentalCost   Float?

  // Per-day breakdown captured at release time. Shape:
  //   [{ day: "YYYY-MM-DD", jobs: number|null, subtotal: number, capped: bool }]
  // `jobs` is null for flat-daily billing; a count for per-job billing.
  // Stored so receipts / "my charges" views can reconstruct the math
  // without re-running fetchJobsByDayForCheckout. See
  // services/equipment.ts computeRentalCost.
  rentalBreakdown Json?

  // Group rentals: when set, the checkout is owned by the group's claimer
  // (still tracked in userId) but the cost is split among workers per
  // CheckoutSplit rows materialized at release time. Null = solo checkout.
  groupId String?
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  equipment Equipment       @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  splits    CheckoutSplit[]

  // Helpful indexes; the “one active checkout” guarantee is added via a partial unique index in SQL
  @@index([equipmentId, releasedAt])
  @@index([userId, checkedOutAt])
  @@index([groupId])
}

// Per-worker share of a group rental. Created at release time from the
// group's per-member equipmentCostPercent (or even-split among workers
// when no percents are configured). Observers are excluded — they don't
// earn or pay for equipment.
model CheckoutSplit {
  id         String   @id @default(cuid())
  checkoutId String
  checkout   Checkout @relation(fields: [checkoutId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  percent    Float
  amount     Float
  createdAt  DateTime @default(now())

  @@unique([checkoutId, userId])
  @@index([userId])
}

model AuditEvent {
  id String @id @default(cuid())

  scope  AuditScope
  verb   AuditVerb
  action String?    @db.VarChar(64)

  actorUserId String?
  metadata    Json?

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([scope, createdAt])
  @@index([verb, createdAt])
  @@index([scope, verb, createdAt])
}

enum ClientType {
  PERSON
  ORGANIZATION
  COMMUNITY
}

enum ClientStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

// TODO: Next time this needs a new value, convert to JSON-settings taxonomy (same pattern as PAYMENT_METHODS) instead of adding the value. See services/paymentMethods.ts for the pattern.
enum PropertyKind {
  SINGLE
  AGGREGATE_SITE
}

// TODO: Next time this needs a new value, convert to JSON-settings taxonomy (same pattern as PAYMENT_METHODS) instead of adding the value. See services/paymentMethods.ts for the pattern.
enum ContactRole {
  OWNER
  SPOUSE
  COMMUNITY_MANAGER
  PROPERTY_MANAGER
  BILLING
  TECHNICAL
  OPERATIONS
  LEGAL
  OTHER
}

enum ContactStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum PropertyStatus {
  ACTIVE
  ARCHIVED
}

model Client {
  id          String     @id @default(cuid())
  type        ClientType
  displayName String

  status ClientStatus @default(ACTIVE)

  isVip     Boolean @default(false)
  vipReason String?

  notesInternal String?
  adminTags     String? // JSON string array e.g. ["LATE_PAYER","ARGUMENTATIVE"] — admin-only

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  //TODO: NOT BEING USED YET, BUT SHOULD MAKE ALL ENTITIES BE RETIRED/ARCHIVED
  archivedAt DateTime?

  // Relations
  contacts   ClientContact[]
  properties Property[]
  jobClients JobClient[]
  followups  FollowupClient[]

  @@index([status])
  @@index([displayName])
}

model ClientContact {
  id String @id @default(cuid())

  status ContactStatus @default(ACTIVE)

  // Belongs to Client
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Identity
  firstName       String
  lastName        String
  nickname        String?
  email           String?
  phone           String? // raw as entered
  normalizedPhone String? @db.VarChar(20) // E.164 for dedupe/lookup

  role      ContactRole?
  isPrimary Boolean      @default(false)

  clerkUserId String? @unique

  // Auto-learned from each approved payment — used to pre-select the method
  // in the worker's Record Payment dialog and to highlight the same method
  // first on the public /pay/[token] page.
  // Stored as a free string keyed to the PAYMENT_METHODS taxonomy (Settings).
  preferredPaymentMethod String?

  // Set when this contact signs up for an account via the post-payment
  // nudge on /pay/[token]. Drives future discount/credit logic — kept now
  // so we can apply retroactive credits when that feature ships.
  clientAccountCreatedFromPaymentPageAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  propertiesAsPOC Property[] @relation("PropertyPOC")

  // Backref from Property.pointOfContactId targets this model

  jobContacts JobContact[]

  // Email + normalizedPhone are GLOBALLY unique. That's load-bearing for
  // the Clerk auto-link in /client/link: when a new Clerk user signs in,
  // we find their ClientContact by email match. If two contacts on
  // different clients shared the same email, that lookup would be
  // non-deterministic and risk binding the Clerk identity to the wrong
  // client. One identity, one contact. The recreate-after-delete edge
  // case is handled by surfacing the existing contact via the pre-flight
  // check in ContactDialog (admin clears the old row before reusing the
  // email).
  // Postgres allows multiple NULLs in UNIQUE constraints—works for optional fields:
  @@unique([email])
  @@unique([normalizedPhone])
  @@index([clientId, status])
}

model Property {
  id String @id @default(cuid())

  // Belongs to Client
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  kind PropertyKind @default(SINGLE)

  // Labels & addressing
  displayName String
  street1     String
  street2     String?
  city        String
  state       String
  postalCode  String
  country     String

  // Optional geo
  //lat                Float?
  //lng                Float?
  //geohash            String

  // Aggregate-site (community) fields (optional)
  //unitLabel          String?        // e.g., "home", "lot", "unit"
  //unitCount          Int?
  //siteName           String?
  //siteBoundaryGeo    Json?          // polygon/bbox later if needed

  // Default point of contact for this property
  pointOfContactId String?
  pointOfContact   ClientContact? @relation("PropertyPOC", fields: [pointOfContactId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // Property size
  lotSize     Float?
  lotSizeUnit String? // e.g. "sqft", "acres", "hectares"

  // Light ops
  accessNotes String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  archivedAt  DateTime?

  status PropertyStatus @default(ACTIVE)

  jobs   Job[]
  photos PropertyPhoto[]

  @@index([clientId])
  @@index([kind])
}

